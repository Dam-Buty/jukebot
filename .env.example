# Discord
DISCORD_TOKEN=your-bot-token
DISCORD_CLIENT_ID=your-app-id
DISCORD_GUILD_ID=your-server-id

# Channels
PLAYLIST_CHANNEL_ID=text-channel-id
VOICE_CHANNEL_ID=voice-channel-id

# Behaviour (optional)
IDLE_DISCONNECT_MINUTES=15
LOG_LEVEL=info

# Set to "production" in Docker (container does this automatically)
NODE_ENV=development
